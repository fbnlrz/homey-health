        "en": "You woke up",
        "de": "Du bist aufgewacht",
        "nl": "Je bent wakker geworden"
      },
      "hint": {
        "en": "Fires when a freshly ended night's sleep is synced (within 4 hours of waking). Perfect for morning routines.",
        "de": "Löst aus, wenn eine frisch beendete Nachtruhe synchronisiert wird (innerhalb von 4 Stunden nach dem Aufwachen). Perfekt für Morgenroutinen.",
        "nl": "Wordt geactiveerd wanneer een net beëindigde nachtrust wordt gesynchroniseerd (binnen 4 uur na het ontwaken). Perfect voor ochtendroutines."
      },
      "tokens": [
        {
          "name": "hours_asleep",
          "type": "number",
          "title": {
            "en": "Hours asleep",
            "de": "Stunden geschlafen",
            "nl": "Uren geslapen"
          },
          "example": 7.4
        },
        {
          "name": "minutes_awake",
          "type": "number",
          "title": {
            "en": "Minutes awake",
            "de": "Minuten wach",
            "nl": "Minuten wakker"
          },
          "example": 32
        },
        {
          "name": "wake_time",
          "type": "string",
