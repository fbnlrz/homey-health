{
  "triggers": [
    {
      "id": "steps_updated",
      "title": {
        "en": "The step count changed",
        "de": "Die Schrittzahl hat sich geändert",
        "nl": "Het aantal stappen is veranderd"
      },
      "tokens": [
        {
          "name": "steps",
          "type": "number",
          "title": {
            "en": "Steps",
            "de": "Schritte",
            "nl": "Stappen"
          },
          "example": 8500
        }
      ]
    },
    {
      "id": "step_goal_reached",
      "title": {
        "en": "The daily step goal was reached",
        "de": "Das tägliche Schrittziel wurde erreicht",
        "nl": "Het dagelijkse stappendoel is bereikt"
      },
      "tokens": [
        {
          "name": "steps",
          "type": "number",
          "title": {
            "en": "Steps",
            "de": "Schritte",
            "nl": "Stappen"
          },
          "example": 10021
        },
        {
          "name": "goal",
          "type": "number",
          "title": {
            "en": "Goal",
            "de": "Ziel",
            "nl": "Doel"
          },
          "example": 10000
        }
      ]
    },
    {
      "id": "heart_rate_updated",
      "title": {
        "en": "A new heart rate reading arrived",
        "de": "Eine neue Herzfrequenz-Messung ist eingetroffen",
        "nl": "Er is een nieuwe hartslagmeting binnengekomen"
      },
      "tokens": [
        {
          "name": "heart_rate",
          "type": "number",
          "title": {
            "en": "Heart rate",
            "de": "Herzfrequenz",
            "nl": "Hartslag"
          },
          "example": 72
        }
      ]
    },
    {
      "id": "heart_rate_crossed",
      "title": {
        "en": "The heart rate crossed a threshold...",
        "de": "Die Herzfrequenz hat einen Schwellenwert gekreuzt...",
        "nl": "De hartslag heeft een drempel gekruist..."
      },
      "titleFormatted": {
        "en": "The heart rate went [[direction]] [[bpm]] bpm",
        "de": "Die Herzfrequenz ging [[direction]] [[bpm]] bpm",
        "nl": "De hartslag ging [[direction]] [[bpm]] bpm"
      },
      "hint": {
        "en": "Fires when a new reading crosses the threshold compared to the previous reading. Note: readings arrive at the poll interval, not in realtime.",
        "de": "Löst aus, wenn eine neue Messung den Schwellenwert gegenüber der vorherigen Messung kreuzt. Hinweis: Messungen kommen im Abrufintervall, nicht in Echtzeit.",
        "nl": "Wordt geactiveerd wanneer een nieuwe meting de drempel kruist ten opzichte van de vorige meting. Let op: metingen komen binnen op het poll-interval, niet realtime."
      },
      "args": [
        {
          "name": "direction",
          "type": "dropdown",
          "values": [
            {
              "id": "above",
              "label": {
                "en": "above",
                "de": "über",
                "nl": "boven"
              }
            },
            {
              "id": "below",
              "label": {
                "en": "below",
                "de": "unter",
                "nl": "onder"
              }
            }
          ]
        },
        {
          "name": "bpm",
          "type": "number",
          "min": 30,
          "max": 220,
          "placeholder": {
            "en": "120",
            "nl": "120"
          }
        }
      ],
      "tokens": [
        {
          "name": "heart_rate",
          "type": "number",
          "title": {
            "en": "Heart rate",
            "de": "Herzfrequenz",
            "nl": "Hartslag"
          },
          "example": 128
        }
      ]
    },
    {
      "id": "resting_hr_elevated",
      "title": {
        "en": "The resting heart rate is above its 7-day average...",
        "de": "Der Ruhepuls liegt über seinem 7-Tage-Durchschnitt...",
        "nl": "De rusthartslag ligt boven het 7-daagse gemiddelde..."
      },
      "titleFormatted": {
        "en": "The resting heart rate is more than [[delta]] bpm above its 7-day average",
        "de": "Der Ruhepuls liegt mehr als [[delta]] bpm über seinem 7-Tage-Durchschnitt",
        "nl": "De rusthartslag ligt meer dan [[delta]] bpm boven het 7-daagse gemiddelde"
      },
      "hint": {
        "en": "Checked once per day when a new daily resting heart rate arrives. An elevated resting heart rate can indicate stress, illness or poor recovery.",
        "de": "Wird einmal täglich geprüft, sobald ein neuer Tages-Ruhepuls eintrifft. Ein erhöhter Ruhepuls kann auf Stress, Krankheit oder schlechte Erholung hindeuten.",
        "nl": "Wordt één keer per dag gecontroleerd zodra een nieuwe dagelijkse rusthartslag binnenkomt. Een verhoogde rusthartslag kan wijzen op stress, ziekte of slecht herstel."
      },
      "args": [
        {
          "name": "delta",
          "type": "number",
          "min": 1,
          "max": 30,
          "placeholder": {
            "en": "5",
            "nl": "5"
          }
        }
      ],
      "tokens": [
        {
          "name": "resting_hr",
          "type": "number",
          "title": {
            "en": "Resting heart rate",
            "de": "Ruhepuls",
            "nl": "Rusthartslag"
          },
          "example": 62
        },
        {
          "name": "baseline",
          "type": "number",
          "title": {
            "en": "7-day average",
            "de": "7-Tage-Durchschnitt",
            "nl": "7-daags gemiddelde"
          },
          "example": 56.4
        },
        {
          "name": "difference",
          "type": "number",
          "title": {
            "en": "Difference",
            "de": "Differenz",
            "nl": "Verschil"
          },
          "example": 5.6
        }
      ]
    },
    {
      "id": "new_weight_measurement",
      "title": {
        "en": "A new weight measurement arrived",
