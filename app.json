          "en": "A new heart rate reading arrived",
          "de": "Eine neue Herzfrequenz-Messung ist eingetroffen",
          "nl": "Er is een nieuwe hartslagmeting binnengekomen"
        },
        "tokens": [
          {
            "name": "heart_rate",
            "type": "number",
            "title": {
              "en": "Heart rate",
              "de": "Herzfrequenz",
              "nl": "Hartslag"
            },
            "example": 72
          }
        ],
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=google-health-user"
          }
        ]
      },
      {
