          "de": "Der Ruhepuls liegt über seinem 7-Tage-Durchschnitt...",
          "nl": "De rusthartslag ligt boven het 7-daagse gemiddelde..."
        },
        "titleFormatted": {
          "en": "The resting heart rate is more than [[delta]] bpm above its 7-day average",
          "de": "Der Ruhepuls liegt mehr als [[delta]] bpm über seinem 7-Tage-Durchschnitt",
          "nl": "De rusthartslag ligt meer dan [[delta]] bpm boven het 7-daagse gemiddelde"
        },
        "hint": {
          "en": "Checked once per day when a new daily resting heart rate arrives. An elevated resting heart rate can indicate stress, illness or poor recovery.",
          "de": "Wird einmal täglich geprüft, sobald ein neuer Tages-Ruhepuls eintrifft. Ein erhöhter Ruhepuls kann auf Stress, Krankheit oder schlechte Erholung hindeuten.",
          "nl": "Wordt één keer per dag gecontroleerd zodra een nieuwe dagelijkse rusthartslag binnenkomt. Een verhoogde rusthartslag kan wijzen op stress, ziekte of slecht herstel."
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=google-health-user"
          },
          {
            "name": "delta",
            "type": "number",
            "min": 1,
            "max": 30,
            "placeholder": {
              "en": "5",
              "nl": "5"
            }
          }
        ],
        "tokens": [
          {
            "name": "resting_hr",
            "type": "number",
            "title": {
              "en": "Resting heart rate",
              "de": "Ruhepuls",
              "nl": "Rusthartslag"
            },
            "example": 62
          },
          {
            "name": "baseline",
            "type": "number",
            "title": {
              "en": "7-day average",
              "de": "7-Tage-Durchschnitt",
              "nl": "7-daags gemiddelde"
            },
            "example": 56.4
          },
          {
            "name": "difference",
            "type": "number",
            "title": {
              "en": "Difference",
              "de": "Differenz",
              "nl": "Verschil"
            },
            "example": 5.6
          }
        ]
      },
      {
