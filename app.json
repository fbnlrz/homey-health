              "en": "Steps",
              "de": "Schritte",
              "nl": "Stappen"
            },
            "example": 8500
          }
        ],
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=google-health-user"
          }
        ]
      },
      {
        "id": "step_goal_reached",
