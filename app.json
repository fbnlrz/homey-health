              },
              {
                "id": "below",
                "label": {
                  "en": "below",
                  "de": "unter",
                  "nl": "onder"
                }
              }
            ]
          },
          {
            "name": "bpm",
            "type": "number",
            "min": 30,
            "max": 220,
            "placeholder": {
              "en": "120",
              "nl": "120"
            }
          }
        ],
